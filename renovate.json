{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "packageRules": [
    {
      "matchPackageNames": ["kubernetes-sigs/kustomize"],
      "versioning": "semver",
      "extractVersion": "^kustomize\/v(?<version>\\d+\\.\\d+\\.\\d+)$"
    },
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "Patch Upgrades",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor"],
      "groupName": "Minor Upgrades",
      "automerge": false
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+ARG .*?=(?<currentValue>.*)"
      ],
      "extractVersionTemplate": "{{#if (equals depName 'curl/curl')}}{{{replace '_' '.' version}}}{{else}}{{{version}}}{{/if}}",
      "versioningTemplate": "{{#if (equals depName 'curl/curl')}}semver{{else}}semver-coerced{{/if}}"
    }
  ]
}
