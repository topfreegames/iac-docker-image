{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "packageRules": [
    {
      "matchPackageNames": ["curl/curl"],
      "versioning": "regex:^(?<major>\\d+)[._](?<minor>\\d+)[._](?<patch>\\d+)$",
      "extractVersion": "^curl-(?<version>\\d+\\_\\d+\\_\\d+)$",
      "extractVersionTemplate": "{{replace '_' '.' version}}"
    },
    {
      "matchPackageNames": ["kubernetes-sigs/kustomize"],
      "versioning": "semver",
      "extractVersion": "^kustomize\/v(?<version>\\d+\\.\\d+\\.\\d+)$"
    },
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "Patch Upgrades",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor"],
      "groupName": "Minor Upgrades",
      "automerge": false
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+ARG .*?=(?<currentValue>.*)"
      ]
    }
  ]
}
