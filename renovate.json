{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "allowedPostUpgradeCommands": ["node renovate-sync-alpine-depnames.js"],
  "packageRules": [
    {
      "matchPackageNames": ["curl/curl"],
      "versioning": "regex:^(?<major>\\d+)[._](?<minor>\\d+)[._](?<patch>\\d+)$",
      "extractVersion": "^curl-(?<version>\\d+_\\d+_\\d+)$"
    },
    {
      "matchPackageNames": ["kubernetes-sigs/kustomize"],
      "versioning": "semver",
      "extractVersion": "^kustomize\/v(?<version>\\d+\\.\\d+\\.\\d+)$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["alpine"],
      "groupName": "Alpine Base Image",
      "postUpgradeTasks": {
        "commands": ["node renovate-sync-alpine-depnames.js"],
        "fileFilters": ["Dockerfile"]
      }
    },
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "Patch Upgrades",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor"],
      "groupName": "Minor Upgrades",
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\s+ARG .*?=(?<currentValue>.*)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "# curl-renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?) version=(?<currentValue>\\S+)\\s+ARG CURL_VERSION=(?<currentValueDocker>\\S+)"
      ],
      "autoReplaceStringTemplate": "# curl-renovate: datasource={{{datasource}}} depName={{{depName}}} version={{{newValue}}}\nARG CURL_VERSION={{{replace '_' '.' newValue}}}"
    }
  ]
}
