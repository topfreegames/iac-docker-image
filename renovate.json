{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "baseBranches": ["master"],
  "rebaseWhen": "behind-base-branch",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "packageRules": [
    {
      "matchPackageNames": ["kubernetes-sigs/kustomize"],
      "versioning": "semver",
      "extractVersion": "^kustomize\/v(?<version>\\d+\\.\\d+\\.\\d+)$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["alpine"],
      "groupName": "Base Image Upgrades"
    },
    {
      "matchUpdateTypes": ["patch"],
      "excludePackageNames": ["alpine"],
      "groupName": "Patch Upgrades",
      "automerge": true,
      "automergeStrategy": "squash"
    },
    {
      "matchUpdateTypes": ["minor"],
      "excludePackageNames": ["alpine"],
      "groupName": "Minor Upgrades",
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\s+ARG .*?=(?<currentValue>.*)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    }
  ]
}
